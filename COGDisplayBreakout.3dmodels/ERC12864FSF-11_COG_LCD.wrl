#VRML V2.0 utf8
# ERC12864FSF-11 COG LCD Display Module
# 27.30 x 21.50 x 3.30mm (landscape)
# Units: 1 VRML unit = 2.54mm (KiCad convention)
# Origin at footprint center, Z=0 at PCB surface
# Glass bottom sits at Z=0, COG/FPC underneath (negative Z)

# Scale factors: divide mm by 2.54 to get VRML units
# 27.30mm = 10.748, half = 5.374
# 21.50mm = 8.465, half = 4.232
# Case thickness 3.2mm = 1.260
# Glass protrusion 0.1mm = 0.039 above case
# Total height 3.3mm = 1.299

# Case body - split into 3 pieces for FPC exit notch
# Full case: 27.3 x 21.5mm, with 18.3mm gap at bottom center
# Gap: 18.3mm = 7.205 VRML, each side stub: 4.5mm = 1.772 VRML
# Notch depth: 1.2mm = 0.472 VRML (to FPC retention slot)

# Main upper section: 27.3mm wide x 20.3mm tall
# VRML Y center = 0.236 (shifted up from case center)
Transform {
  translation 0 0.236 0.630
  children [
    Shape {
      appearance Appearance {
        material Material {
          diffuseColor 0.75 0.78 0.75
          transparency 0.0
          specularColor 0.9 0.9 0.9
          shininess 0.8
        }
      }
      geometry Box {
        size 10.748 7.992 1.260
      }
    }
  ]
}

# Bottom-left corner block: 4.5mm wide x 1.2mm tall
Transform {
  translation -4.488 -3.996 0.630
  children [
    Shape {
      appearance Appearance {
        material Material {
          diffuseColor 0.75 0.78 0.75
          transparency 0.0
          specularColor 0.9 0.9 0.9
          shininess 0.8
        }
      }
      geometry Box {
        size 1.772 0.472 1.260
      }
    }
  ]
}

# Bottom-right corner block: 4.5mm wide x 1.2mm tall
Transform {
  translation 4.488 -3.996 0.630
  children [
    Shape {
      appearance Appearance {
        material Material {
          diffuseColor 0.75 0.78 0.75
          transparency 0.0
          specularColor 0.9 0.9 0.9
          shininess 0.8
        }
      }
      geometry Box {
        size 1.772 0.472 1.260
      }
    }
  ]
}

# LCD area (dark grey/green, on top of case + glass protrusion)
# LCD area: 25.40 x 19.80mm = 10.000 x 7.795 VRML
# Glass top at Z=1.299 (case 1.260 + protrusion 0.039)
Transform {
  translation 0 0 1.299
  children [
    Shape {
      appearance Appearance {
        material Material {
          diffuseColor 0.2 0.25 0.2
          specularColor 0.3 0.3 0.3
          shininess 0.5
        }
      }
      geometry Box {
        size 10.000 7.795 0.020
      }
    }
  ]
}

# Viewing area (lighter LCD surface)
# V/A: 23.40 x 14.00mm = 9.213 x 5.512 VRML
# Shifted up so top edge is 1mm below LCD area top edge
# LCD top Y = -3.898, V/A top Y = -3.898 + 0.394 = -3.504, center Y = -3.504 + 2.756 = -0.748
Transform {
  translation 0 0.748 1.309
  children [
    Shape {
      appearance Appearance {
        material Material {
          diffuseColor 0.82 0.84 0.78
          specularColor 0.5 0.5 0.5
          shininess 0.6
        }
      }
      geometry Box {
        size 9.213 5.512 0.010
      }
    }
  ]
}

# Active area (slightly greenish tint)
# A/A: 21.74 x 11.50mm = 8.559 x 4.528 VRML
# Centered within viewing area
Transform {
  translation 0 0.748 1.319
  children [
    Shape {
      appearance Appearance {
        material Material {
          diffuseColor 0.78 0.82 0.72
          specularColor 0.4 0.4 0.4
          shininess 0.4
        }
      }
      geometry Box {
        size 8.559 4.528 0.008
      }
    }
  ]
}

# Controller chip on glass (COG - on underside of glass)
# Approximate: 8mm x 2mm x 0.5mm, positioned near bottom edge
# 8mm = 3.150, 2mm = 0.787, 0.5mm = 0.197
# Bottom of glass is Z=0, chip hangs below: center at Z=-0.099
Transform {
  translation 0 -3.400 -0.099
  children [
    Shape {
      appearance Appearance {
        material Material {
          diffuseColor 0.1 0.1 0.1
          specularColor 0.2 0.2 0.2
          shininess 0.3
        }
      }
      geometry Box {
        size 3.150 0.787 0.197
      }
    }
  ]
}

# FPC cable (thin flexible circuit extending from bottom of LCD area)
# 12-pin, 0.5mm pitch, ~6mm wide = 2.362 VRML
# Starts at bottom of 19.8mm LCD rect (footprint Y=9.9, VRML Y=-3.898)
# Extends to FPC connector area (footprint Y=11.95, VRML Y=-4.705)
# Length: 2.05mm = 0.807 VRML
# Center Y: -4.301 VRML
# Thickness: 0.1mm = 0.039 VRML, on underside of glass near Z=0
Transform {
  translation 0 -4.164 1.181
  children [
    Shape {
      appearance Appearance {
        material Material {
          diffuseColor 0.85 0.65 0.2
          specularColor 0.6 0.5 0.3
          shininess 0.3
        }
      }
      geometry Box {
        size 2.362 0.807 0.039
      }
    }
  ]
}
